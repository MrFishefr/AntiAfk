local player = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ItemData = require(ReplicatedStorage:WaitForChild("ItemData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))

local invGui = script.Parent
local inner = invGui:WaitForChild("Inner")
local info = invGui:WaitForChild("Info")
local feedMenu = invGui:FindFirstChild("FeedMenu", true)
local scrollingFrame = inner:FindFirstChild("InvScrollFrame", true)
local openBtn = player.PlayerGui:WaitForChild("MainGui"):FindFirstChild("Inventory", true)

local currentFilter, selectedFood, currentFeedingPetID = "Pets", {}, nil

local function toggleInventory(state)
	for _, v in ipairs({invGui.Outter, invGui.Header, inner, invGui.ImageButton}) do v.Visible = state end
	if not state then info.Enabled = false if feedMenu then feedMenu.Visible = false end end
end

local function getPet(petID)
	for _, f in ipairs({player:FindFirstChild("EquippedPets"), player:FindFirstChild("Pets")}) do
		if f then for _, c in ipairs(f:GetChildren()) do 
				if c:GetAttribute("ID") == petID or c.Name == petID then return c end 
			end end
	end
end

local function updateFeedUI(petID)
	local pet = getPet(petID)
	if not pet or not feedMenu then return end
	local header = feedMenu:FindFirstChild("PetHeader", true)
	if header then
		local lvl, xp = pet:GetAttribute("Level") or 1, pet:GetAttribute("XP") or 0
		local pData = PetData[pet.Name]
		local maxXP = pData and (pData.XPRequirement * lvl) or 100
		header:FindFirstChild("NameLabel", true).Text = pet.Name .. " [Lvl " .. lvl .. "]"
		local bar = header:FindFirstChild("XPBar", true)
		bar.Fill.Size = UDim2.new(math.clamp(xp/maxXP, 0, 1), 0, 1, 0)
		bar:FindFirstChildOfClass("TextLabel").Text = xp .. " / " .. maxXP
		local vp = header:FindFirstChild("ViewportFrame", true)
		vp:ClearAllChildren()
		local model = ReplicatedStorage.Assets.PetModels:FindFirstChild(pet.Name)
		if model then
			local cl = model:Clone() cl.Parent = vp
			local cam = Instance.new("Camera", vp)
			local hrp = cl.PrimaryPart or cl:FindFirstChild("HumanoidRootPart")
			cam.CFrame = CFrame.new(hrp.Position + hrp.CFrame.LookVector * 4 + Vector3.new(0,1,0), hrp.Position)
			vp.CurrentCamera = cam
		end
	end
end

local function showFoodSelection(petID)
	currentFeedingPetID, selectedFood = petID, {}
	local scroll = feedMenu:FindFirstChildOfClass("ScrollingFrame")
	for _, c in ipairs(scroll:GetChildren()) do if c:IsA("GuiButton") then c:Destroy() end end
	for _, item in ipairs(player.Inventory:GetChildren()) do
		local data = ItemData[item.Name]
		if data and data.Type == "Food" then
			local slot = Instance.new("ImageButton")
			slot.Size, slot.BackgroundColor3, slot.Parent = UDim2.new(0,80,0,80), Color3.fromRGB(55,55,55), scroll
			Instance.new("UICorner", slot)
			local txt = Instance.new("TextLabel", slot)
			txt.Size, txt.BackgroundTransparency, txt.Text = UDim2.new(1,0,1,0), 1, item.Name.."\n+"..(data.XPValue or 0).."XP"
			txt.TextScaled, txt.TextColor3 = true, Color3.new(1,1,1)
			slot.MouseButton1Click:Connect(function()
				
				local id = item:GetAttribute("ID") or item.Name
				local f = table.find(selectedFood, id)
				if f then table.remove(selectedFood, f) slot.BackgroundColor3 = Color3.fromRGB(55,55,55)
				else table.insert(selectedFood, id) slot.BackgroundColor3 = Color3.fromRGB(100,100,50) end
			end)
		end
	end
	updateFeedUI(petID)
end

local function updateInventory()
	scrollingFrame.ClipsDescendants = false
	for _, c in ipairs(scrollingFrame:GetChildren()) do if c:IsA("GuiObject") then c:Destroy() end end
	local function process(folder, isEq)
		if not folder then return end
		for _, item in ipairs(folder:GetChildren()) do
			local data = PetData[item.Name] or ItemData[item.Name]
			if currentFilter == "All" or (data and data.Type == currentFilter) then
				local slot = Instance.new("ImageButton")
				slot.Size, slot.LayoutOrder, slot.Parent = UDim2.new(0,100,0,100), (isEq and 1 or 100), scrollingFrame
				slot.BackgroundColor3 = data.RarityColor or Color3.fromRGB(45,45,45)
				Instance.new("UICorner", slot)
				local str = Instance.new("UIStroke", slot)
				str.Thickness, str.ApplyStrokeMode = 3, "Border"
				local h,s,v = slot.BackgroundColor3:ToHSV() str.Color = Color3.fromHSV(h,s,v-0.2)
				if isEq then
					local ch = Instance.new("ImageLabel", slot)
					ch.Size, ch.Position, ch.Image = UDim2.new(0,25,0,25), UDim2.new(1,-22,0,-3), "rbxassetid://6031068433"
					ch.BackgroundTransparency, ch.ImageColor3 = 1, Color3.new(0,1,0)
				end
				if data.Type == "Pets" then
					local m = ReplicatedStorage.Assets.PetModels:FindFirstChild(item.Name)
					if m then
						local vp = Instance.new("ViewportFrame", slot)
						vp.Size, vp.BackgroundTransparency = UDim2.new(0.9,0,0.8,0), 1
						local cl = m:Clone() cl.Parent = vp
						local head = cl:FindFirstChild("Head") or cl.PrimaryPart
						local cam = Instance.new("Camera", vp)
						cam.CFrame = CFrame.new(head.Position + head.CFrame.LookVector*2.2 + Vector3.new(0,0.4,0), head.Position+Vector3.new(0,0.4,0))
						vp.CurrentCamera = cam
					end
				elseif data.ImageID then
					local img = Instance.new("ImageLabel", slot)
					img.Size, img.Position, img.Image = UDim2.new(0,70,0,70), UDim2.new(0.15,0,0.1,0), "rbxassetid://"..data.ImageID
					img.BackgroundTransparency = 1
				end
				local nl = Instance.new("TextLabel", slot)
				nl.Size, nl.Position, nl.Text = UDim2.new(1,0,0.25,0), UDim2.new(0,0,0.7,0), item.Name
				nl.TextScaled, nl.Font, nl.BackgroundTransparency = true, "GothamBold", 1
				Instance.new("UIStroke", nl).Thickness = 2
				slot.MouseButton1Click:Connect(function()
					info.Enabled = true
					local inI = info:FindFirstChild("Inner", true)
					local ds = inI:FindFirstChild("DescText", true)
					if ds then 
						ds.Text = (data and data.Description) or "No Description" 
					end
					local lvl = item:GetAttribute("Level") or 1
					inI.NameText.Text = item.Name .. " [Lvl " .. lvl .. "]"
					local rl = inI:FindFirstChild("RarityText")
					if rl then rl.Text, rl.TextColor3 = data.Rarity or "Common", data.RarityColor or Color3.new(1,1,1) end
					local b = {}
					if data.DamageMul then table.insert(b, "x"..data.DamageMul.." Dmg") end
					if data.EnergyMul then table.insert(b, "x"..data.EnergyMul.." En") end
					local feed = info:FindFirstChild("Feed", true)
					if feed then
						feed.Visible = (data.Type == "Pets")
						if _G.F then _G.F:Disconnect() end
						_G.F = feed.MouseButton1Click:Connect(function()
							feedMenu.Visible = not feedMenu.Visible
							if feedMenu.Visible then
								currentFeedingPetID = item:GetAttribute("ID") or item.Name
								showFoodSelection(currentFeedingPetID) 
							end
						end)
					end
					if _G.AttrConn then _G.AttrConn:Disconnect() end
					_G.AttrConn = item:GetAttributeChangedSignal("Level"):Connect(function()
						local newLvl = item:GetAttribute("Level") or 1
						if inI:FindFirstChild("NameText") then
							inI.NameText.Text = item.Name .. " [Lvl " .. newLvl .. "]"
						end
					end)
					local eq = info:FindFirstChild("Equip", true)
					local bt = eq:FindFirstChildOfClass("TextLabel")
					bt.Text = isEq and "UNEQUIP" or "EQUIP"
					if _G.E then _G.E:Disconnect() end
					_G.E = eq.MouseButton1Click:Connect(function() ReplicatedStorage.Remotes.EquipItem:FireServer(item:GetAttribute("ID") or item.Name) end)
				end)
			end
		end
	end
	process(player:FindFirstChild("Inventory"), false) process(player:FindFirstChild("Equipped"), true)
	process(player:FindFirstChild("Pets"), false) process(player:FindFirstChild("EquippedPets"), true)
end

openBtn.MouseButton1Click:Connect(function() local v = not invGui.Outter.Visible if v then currentFilter = "Pets" updateInventory() end toggleInventory(v) end)
invGui.ImageButton.MouseButton1Click:Connect(function() toggleInventory(false) end)
local fMap = {Filter1 = "Pets", Filter2 = "Armor", Filter3 = "Sword"}
for _, b in ipairs(inner:WaitForChild("Filters"):GetChildren()) do if b:IsA("GuiObject") then b.MouseButton1Click:Connect(function() currentFilter = fMap[b.Name] or "All" updateInventory() end) end end
if feedMenu then
	feedMenu:FindFirstChild("Confirm", true).MouseButton1Click:Connect(function() if #selectedFood > 0 then ReplicatedStorage.Remotes.FeedPet:FireServer(currentFeedingPetID, selectedFood) selectedFood = {} feedMenu.Visible = false end end)
	feedMenu:FindFirstChild("Cancel", true).MouseButton1Click:Connect(function() feedMenu.Visible = false end)
	feedMenu:FindFirstChild("All", true).MouseButton1Click:Connect(function() selectedFood = {} for _, i in ipairs(player.Inventory:GetChildren()) do if ItemData[i.Name] and ItemData[i.Name].Type == "Food" then table.insert(selectedFood, i:GetAttribute("ID") or i.Name) end end if currentFeedingPetID then showFoodSelection(currentFeedingPetID) end end)
end
for _, f in ipairs({player:WaitForChild("Inventory"), player:WaitForChild("Equipped"), player:WaitForChild("Pets"), player:WaitForChild("EquippedPets")}) do f.ChildAdded:Connect(updateInventory) f.ChildRemoved:Connect(updateInventory) end
toggleInventory(false) invGui.Enabled = true
